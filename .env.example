VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SOLANA_CLUSTER=devnet
VITE_SOLANA_RPC=
VITE_USDC_MINT_DEVNET=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
VITE_PROGRAM_ID=6m2ipcrUCRpSqkPSqNNKNH11rNmVsu8KmnBLnBtFsq2N

# Whitelist de origens (CSV) pras edge fns autenticadas. Webhook fica aberto.
ALLOWED_ORIGINS=http://localhost:5173

# ─── Supabase Edge runtime (server-side only — set via `supabase secrets set`) ─
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# ⚠️ OBRIGATÓRIO: gerar com `uuidgen` antes do deploy. Boot-check rejeita o default RFC.
WALLET_UUID_NAMESPACE=

# Anthropic Vision (OCR de CNH + extrato Uber)
ANTHROPIC_API_KEY=

# Woovi (Pix sandbox)
WOOVI_API_URL=https://api.openpix.com.br/api/v1
WOOVI_API_KEY=
WOOVI_WEBHOOK_SECRET=
PAYOUT_MAX_BRL=10

